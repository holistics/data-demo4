Dashboard _1_country_breakdown_demo {
  title: '1. Country Breakdown '
  block created_at: FilterBlock {
    label: 'Created At'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_ecommerce_version_2
      field: r(ecommerce_orders.created_at)
    }
    default {
      operator: 'last'
      value: '30'
      modifier: 'day'
      options {
        include_current_period: true
      }
    }
    settings {
      drillthrough: Drillthrough {
        enabled: true
        sources: [
          AutoDrillthroughSource {
            excluded_sources: [
              'ssbi_demo'
            ]
          }
        ]
      }
    }
  }
  block country: FilterBlock {
    label: 'Country'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_ecommerce_version_2
      field: ref('ecommerce_countries', 'name')
    }
    default {
      operator: 'is'
      value: []
    }
    settings {
      drillthrough: Drillthrough {
        enabled: true
        sources: [
          AutoDrillthroughSource {
          }
        ]
      }
    }
  }
  block product_name: FilterBlock {
    label: 'Product Name'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_ecommerce_version_2
      field: ref('ecommerce_products', 'name')
    }
    default {
      operator: 'is'
      value: []
    }
    settings {
      drillthrough: Drillthrough {
        enabled: true
        sources: [
          AutoDrillthroughSource {
          }
        ]
      }
    }
  }
  block customer_gender: FilterBlock {
    label: 'Customer Gender'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_ecommerce_version_2
      field: ref('ecommerce_users', 'gender')
    }
    default {
      operator: 'is'
      value: []
    }
    settings {
      drillthrough: Drillthrough {
        enabled: true
        sources: [
          AutoDrillthroughSource {
          }
        ]
      }
    }
  }
  block city: FilterBlock {
    label: 'City'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_ecommerce_version_2
      field: ref('ecommerce_cities', 'name')
    }
    default {
      operator: 'is'
      value: []
    }
    settings {
      drillthrough: Drillthrough {
        enabled: true
        sources: [
          AutoDrillthroughSource {
          }
        ]
      }
    }
  }
  block age_demographic: FilterBlock {
    label: 'Age Demographic'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_ecommerce_version_2
      field: ref('ecommerce_users', 'age_group')
    }
    default {
      operator: 'is'
      value: []
    }
  }
  block date_drill: DateDrillBlock {
    label: 'Date Drill'
  }
  block v1: VizBlock {
    label: 'Merchant x GMV'
    viz: PivotTable {
      dataset: demo_ecommerce_version_2
      rows: [
        VizFieldFull {
          label: 'Merchant'
          ref: ref('ecommerce_merchants', 'name')
          format {
            type: 'text'
          }
        }
      ]
      values: [
        VizFieldFull {
          ref: 'revenue'
          format {
            type: 'number'
          }
        },
        VizFieldFull {
          ref: 'delivered_value'
          format {
            type: 'number'
          }
        }
      ]
      settings {
        show_row_total: true
        show_column_total: true
        conditional_formats: [
          ConditionalFormat {
            ref: 'revenue'
            format: SingleFormat {
              condition {
                operator: 'less_than'
                value: 20000
              }
              text_color: '#A50E43'
              background_color: '#FCB8B8'
            }
          },
          ConditionalFormat {
            ref: 'revenue'
            format: SingleFormat {
              condition {
                operator: 'greater_than_equal'
                value: 20000
              }
              text_color: '#21908D'
              background_color: '#C3E8C2'
            }
          },
          ConditionalFormat {
            ref: 'delivered_value'
            format: SingleFormat {
              condition {
                operator: 'less_than'
                value: 20000
              }
              text_color: '#A50E43'
              background_color: '#FCB8B8'
            }
          },
          ConditionalFormat {
            ref: 'delivered_value'
            format: SingleFormat {
              condition {
                operator: 'greater_than_equal'
                value: 20000
              }
              text_color: '#21908D'
              background_color: '#C3E8C2'
            }
          }
        ]
      }
    }
  }
  block v2: VizBlock {
    label: 'Sales by City'
    viz: ColumnChart {
      dataset: demo_ecommerce_version_2
      x_axis: VizFieldFull {
        ref: r(ecommerce_cities.name)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(demo_ecommerce_version_2.delivered_value)
            format {
              type: 'number'
              pattern: '[$$]#,###'
            }
          }
          settings {
            color: '#003A61'
          }
        }
      }
      settings {
        sort {
          field_index: 0
          direction: 'asc'
          type: 'yaxis'
        }
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v3: VizBlock {
    label: 'Sales Revenue by Month'
    viz: CombinationChart {
      dataset: demo_ecommerce_version_2
      calculation delivered_value_prev_1_period {
        label: 'Delivered Value (prev. 1 period)'
        formula: @aql delivered_value | relative_period(ecommerce_products.created_at, -1, strict: true);;
        calc_type: 'measure'
        data_type: 'number'
      }
      x_axis: VizFieldFull {
        ref: r(ecommerce_products.created_at)
        transformation: 'datetrunc month'
        format {
          type: 'date'
          pattern: 'LLL yyyy'
        }
      }
      y_axis {
        series {
          mark_type: 'column'
          field: VizFieldFull {
            ref: r(demo_ecommerce_version_2.delivered_value)
            format {
              type: 'number'
            }
          }
          settings {
            color: '#05264C'
          }
        }
        series {
          mark_type: 'line'
          field: VizFieldFull {
            ref: 'delivered_value_prev_1_period'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
          settings {
            color: '#259B6C'
          }
        }
      }
      settings {
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v4: VizBlock {
    label: 'Revenue Delivered by Category'
    viz: ColumnChart {
      dataset: demo_ecommerce_version_2
      x_axis: VizFieldFull {
        ref: r(map_categories.category)
        format {
          type: 'text'
        }
      }
      legend: VizFieldFull {
        ref: r(ecommerce_countries.continent_name)
        format {
          type: 'text'
        }
      }
      y_axis {
        settings {
          group_values_into: 5
          stack_series_by: 'value'
        }
        series {
          field: VizFieldFull {
            ref: r(demo_ecommerce_version_2.delivered_value)
            format {
              type: 'number'
            }
          }
