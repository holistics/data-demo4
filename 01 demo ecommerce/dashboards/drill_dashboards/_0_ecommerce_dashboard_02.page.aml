  block v5: VizBlock {
    label: 'Table View Chart'
    viz: DataTable {
      dataset: demo_ecommerce_version_2
      fields: [
        VizFieldFull {
          ref: ref('ecommerce_countries', 'name')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_countries', 'continent_name')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          label: 'Order Id'
          ref: ref('ecommerce_orders', 'id')
          format {
            type: 'number'
            pattern: 'inherited'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_orders', 'created_date')
          format {
            type: 'date'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_orders', 'status')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          label: 'Product Id'
          ref: ref('ecommerce_products', 'id')
          format {
            type: 'number'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_products', 'name')
          format {
            type: 'text'
          }
        },
        VizFieldFull {
          ref: ref('ecommerce_products', 'merchant_id')
          format {
            type: 'number'
          }
        }
      ]
      settings {
        show_row_number: true
        row_limit: 1000
      }
    }
  }
  block f1: FilterBlock {
    label: 'Date'
    type: 'field'
    source: FieldFilterSource {
      dataset: demo_ecommerce_version_2
      field: r(ecommerce_orders.created_at)
    }
    default {
      operator: 'matches'
      value: '$H_NIL$'
    }
    settings {
      drillthrough: Drillthrough {
        enabled: true
        sources: [
          AutoDrillthroughSource {
            excluded_sources: [
              'ssbi_demo'
            ]
          }
        ]
      }
    }
  }
  interactions: [
    FilterInteraction {
      from: 'created_at'
      to: [
        CustomMapping {
          block: [
            'country',
            'product_name',
            'customer_gender',
            'city',
            'age_demographic',
            'f1'
          ]
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'country'
      to: [
        CustomMapping {
          block: [
            'created_at',
            'product_name',
            'customer_gender',
            'age_demographic',
            'f1'
          ]
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'product_name'
      to: [
        CustomMapping {
          block: [
            'created_at',
            'country',
            'customer_gender',
            'city',
            'age_demographic',
            'f1'
          ]
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'customer_gender'
      to: [
        CustomMapping {
          block: [
            'created_at',
            'country',
            'product_name',
            'city',
            'age_demographic',
            'f1'
          ]
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'city'
      to: [
        CustomMapping {
          block: [
            'created_at',
            'country',
            'product_name',
            'customer_gender',
            'age_demographic',
            'f1'
          ]
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'age_demographic'
      to: [
        CustomMapping {
          block: [
            'created_at',
            'country',
            'product_name',
            'customer_gender',
            'city',
            'f1'
          ]
          disabled: true
        }
      ]
    },
    FilterInteraction {
      from: 'f1'
      to: [
        CustomMapping {
          block: [
            'created_at',
            'country',
            'product_name',
            'customer_gender',
            'city',
            'age_demographic'
          ]
          disabled: true
        }
      ]
    },
    DateDrillInteraction {
      from: 'date_drill'
      to: [
        CustomMapping {
          block: 'v3'
          field: r(ecommerce_products.created_at)
        },
        CustomMapping {
          block: 'v4'
          field: r(ecommerce_orders.created_at)
        },
        CustomMapping {
          block: 'v5'
          field: r(ecommerce_orders.created_date)
        }
      ]
    }
  ]
  view: CanvasLayout {
    label: 'Canvas Layout'
    width: 1220
    height: 1410
    grid_size: 20
    block v1 {
      position: pos(20, 260, 580, 380)
      layer: 1
    }
    block v2 {
      position: pos(620, 260, 580, 380)
      layer: 1
    }
    block v3 {
      position: pos(20, 660, 580, 380)
      layer: 1
    }
    block v4 {
      position: pos(620, 660, 580, 380)
      layer: 1
    }
    block v5 {
      position: pos(20, 1060, 1180, 330)
      layer: 1
    }
    block city {
      position: pos(20, 140, 280, 100)
      layer: 1
    }
    block country {
