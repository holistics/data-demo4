      }
      block t2_by_group {
        position: pos(20, 350, 640, 400)
      }
      block t2_trend {
        position: pos(680, 350, 600, 400)
      }
      block t2_by_dept {
        position: pos(20, 770, 1260, 320)
      }
      block t2_table {
        position: pos(20, 1110, 1260, 440)
      }
      mobile {
        mode: 'auto'
      }
    }

    tab balance_sheet: CanvasLayout {
      label: 'Balance Sheet & Fixed Assets'
      width: 1320
      height: 1230
      grid_size: 20
      auto_expand_vertically: true
      block t3_title {
        position: pos(20, 20, 1280, 64)
      }
      block t3_date_filter {
