      }
      block t3_kpi_net {
        position: pos(20, 170, 400, 160)
      }
      block t3_kpi_credit {
        position: pos(440, 170, 400, 160)
      }
      block t3_kpi_debit {
        position: pos(860, 170, 400, 160)
      }
      block t3_by_group {
        position: pos(20, 350, 640, 400)
      }
      block t3_fixed {
        position: pos(680, 350, 600, 400)
      }
      block t3_table {
        position: pos(20, 770, 1260, 440)
      }
      mobile {
        mode: 'auto'
      }
    }

    tab production: CanvasLayout {
      label: 'Production & Inventory'
      width: 1320
      height: 1570
      grid_size: 20
      auto_expand_vertically: true
      block t4_title {
        position: pos(20, 20, 1280, 64)
      }
      block t4_date_filter {
        position: pos(20, 100, 360, 40)
      }
      block t4_kpi_value {
        position: pos(20, 170, 400, 160)
