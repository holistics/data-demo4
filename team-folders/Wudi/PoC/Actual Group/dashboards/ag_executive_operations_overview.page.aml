Dashboard ag_executive_operations_overview {
  title: 'Actual Group — Executive & Operations Overview'
  description: 'Tabbed exec + operational analytics across revenue, margin, recruitment funnel, delivery, clients and training for the Actual Group staffing PoC.'
  owner: 'chukwudi@holistics.io'

  block b_title: TextBlock {
    content: @md # Actual Group — Executive & Operations Overview\n_“Work is essential.” Multi-region staffing group — revenue, margin, funnel, delivery, clients & training._ ;;
  }

  block f_inv_date: FilterBlock {
    label: 'Invoice Period'
    type: 'field'
    source: FieldFilterSource {
      dataset: ag_revenue_margin
      field: ref('ag_invoice', 'invoice_date')
    }
    default {
      operator: 'matches'
      value: 'last quarter'
    }
  }

  block f_region: FilterBlock {
    label: 'Region'
    type: 'field'
    source: FieldFilterSource {
      dataset: ag_client_retention
      field: ref('ag_region', 'region_name')
    }
    default {
      operator: 'is'
      value: []
    }
    settings { input_type: 'multiple' }
  }

  block f_industry: FilterBlock {
    label: 'Industry'
    type: 'field'
    source: FieldFilterSource {
      dataset: ag_revenue_margin
      field: ref('ag_industry', 'industry_name')
    }
    default {
      operator: 'is'
      value: []
    }
    settings { input_type: 'multiple' }
  }

  block f_client_status: FilterBlock {
    label: 'Client Status'
    type: 'field'
    source: FieldFilterSource {
      dataset: ag_client_retention
      field: ref('ag_client', 'client_status')
    }
    default {
      operator: 'is'
      value: []
    }
    settings { input_type: 'multiple' }
  }

  block k_rev: VizBlock {
    label: 'Total Revenue'
    viz: MetricKpi {
      dataset: ag_revenue_margin
      value: VizFieldFull {
        ref: 'total_revenue'
        format {
          type: 'number'
          pattern: '[$$]#,##0'
        }
      }
      settings {
        display_mode: 'single'
        alignment: 'center'
        metric_value { font_size: 30 }
        label { font_size: 13 }
        row_limit: 1
      }
    }
  }

  block k_gm: VizBlock {
    label: 'Gross Margin'
    viz: MetricKpi {
      dataset: ag_revenue_margin
      value: VizFieldFull {
        ref: 'gross_margin'
        format {
          type: 'number'
          pattern: '[$$]#,##0'
        }
      }
      settings {
        display_mode: 'single'
        alignment: 'center'
        metric_value { font_size: 30 }
        label { font_size: 13 }
        row_limit: 1
      }
    }
  }

  block k_gmr: VizBlock {
    label: 'Gross Margin Rate'
    viz: MetricKpi {
      dataset: ag_revenue_margin
      value: VizFieldFull {
        ref: 'gross_margin_rate'
        format {
          type: 'number'
          pattern: '0.0%'
        }
      }
      settings {
        display_mode: 'single'
        alignment: 'center'
        metric_value { font_size: 30 }
        label { font_size: 13 }
        row_limit: 1
      }
    }
  }

  block k_plc: VizBlock {
    label: 'Total Placements'
    viz: MetricKpi {
      dataset: ag_revenue_margin
      value: VizFieldFull {
        ref: 'total_placements'
        format {
          type: 'number'
          pattern: '#,##0'
        }
      }
      settings {
        display_mode: 'single'
        alignment: 'center'
        metric_value { font_size: 30 }
        label { font_size: 13 }
        row_limit: 1
      }
    }
  }

  block k_ofr: VizBlock {
    label: 'Order Fill Rate'
    viz: MetricKpi {
      dataset: ag_client_retention
      value: VizFieldFull {
        ref: 'order_fill_rate'
        format {
          type: 'number'
          pattern: '0.0%'
        }
      }
      settings {
        display_mode: 'single'
        alignment: 'center'
        metric_value { font_size: 30 }
        label { font_size: 13 }
        row_limit: 1
      }
    }
  }

  block k_qoq: VizBlock {
    label: 'Revenue QoQ Growth'
    viz: MetricKpi {
      dataset: ag_revenue_margin
      value: VizFieldFull {
        ref: 'revenue_qoq_growth'
        format {
          type: 'number'
          pattern: '0.0%'
        }
      }
      settings {
        display_mode: 'single'
        alignment: 'center'
        metric_value { font_size: 30 }
        label { font_size: 13 }
        row_limit: 1
      }
    }
  }

  block c_rev_month: VizBlock {
    label: 'Revenue by Month'
    viz: CombinationChart {
      dataset: ag_revenue_margin
      x_axis: VizFieldFull {
        label: 'Month'
        ref: r(ag_invoice.invoice_date)
        transformation: 'datetrunc month'
        format { type: 'date' pattern: 'LLL yyyy' }
      }
      y_axis {
        series {
          mark_type: 'line'
          field: VizFieldFull {
            label: 'Total Revenue'
            ref: 'total_revenue'
            format {
              type: 'number'
              pattern: '[$$]#,##0'
            }
          }
          settings { color: '#E2231A' }
        }
      }
      settings {
        sort: LineFamilySort { type: 'xaxis' direction: 'asc' }
        show_data_points: true
        row_limit: 5000
      }
    }
  }

  block c_rev_ind: VizBlock {
    label: 'Revenue by Industry'
    viz: CombinationChart {
      dataset: ag_revenue_margin
      x_axis: VizFieldFull {
        label: 'Industry'
        ref: r(ag_industry.industry_name)
        format { type: 'text' }
      }
      y_axis {
        series {
          mark_type: 'column'
          field: VizFieldFull {
            label: 'Total Revenue'
            ref: 'total_revenue'
            format {
              type: 'number'
              pattern: '[$$]#,##0'
            }
          }
          settings { color: '#E2231A' }
        }
      }
      settings {
        row_limit: 5000
      }
    }
  }

