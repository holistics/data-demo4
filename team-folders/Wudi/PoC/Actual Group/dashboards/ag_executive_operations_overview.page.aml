  block h_adv: TextBlock {
    content: @md ## Advanced analytics — conversion funnel, cohort retention & margin bridge ;;
  }

  block v_funnel: VizBlock {
    label: 'Recruitment Conversion Funnel'
    viz: ConversionFunnel {
      dataset: ag_recruitment_funnel
      values: [
        VizFieldFull { ref: 'total_applications' label: 'Applications' format { type: 'number' pattern: '#,##0' } },
        VizFieldFull { ref: 'total_submissions' label: 'Submissions' format { type: 'number' pattern: '#,##0' } },
        VizFieldFull { ref: 'total_interviews' label: 'Interviews' format { type: 'number' pattern: '#,##0' } },
        VizFieldFull { ref: 'total_offers' label: 'Offers' format { type: 'number' pattern: '#,##0' } },
        VizFieldFull { ref: 'total_placements' label: 'Placements' format { type: 'number' pattern: '#,##0' } }
      ]
      settings { columns_color: '#E2231A' show_label: true show_table: true }
    }
  }

  block v_cohort: VizBlock {
    label: 'Client Revenue Cohort (by acquisition month)'
    viz: RetentionHeatmap {
      dataset: ag_client_retention
      filter {
        field: ref('ag_client', 'cohort_month')
        operator: 'last'
        value: 12
        modifier: 'month'
      }
      filter {
        field: ref('ag_invoice', 'months_since_acquisition')
        operator: 'greater_than'
        value: -1
      }
      filter {
        field: ref('ag_invoice', 'months_since_acquisition')
        operator: 'less_than'
        value: 12
      }
      cohort: VizFieldFull {
        ref: ref('ag_client', 'cohort_month')
        transformation: 'datetrunc month'
        format { type: 'date' pattern: 'LLL yyyy' }
      }
      cohort_duration: VizFieldFull { ref: ref('ag_invoice', 'months_since_acquisition') format { type: 'number' } }
      cohort_value: VizFieldFull { ref: 'total_revenue' format { type: 'number' pattern: '[$$]#,##0' } }
      settings { display_percentage_values: false convert_empty_to_zero: true }
    }
  }

  block v_waterfall: VizBlock {
    label: 'Margin Bridge (Revenue → Labor Cost → Gross Margin)'
    viz: CombinationChart {
      dataset: ag_revenue_margin
      x_axis: VizFieldFull { ref: ref('ag_margin_bridge', 'step') format { type: 'text' } }
      y_axis {
        series {
          mark_type: 'column'
          field: VizFieldFull { ref: ref('ag_margin_bridge', 'base_amount') }
          settings { color: '#FFFFFF' }
        }
        series {
          mark_type: 'column'
          field: VizFieldFull { ref: ref('ag_margin_bridge', 'delta_amount') label: 'Amount' format { type: 'number' pattern: '[$$]#,##0' } }
          settings { color: '#E2231A' }
        }
        settings { stack_series_by: 'value' }
      }
      settings { row_limit: 100 }
    }
  }

  block h_adv_note: TextBlock {
    content: @md ### How to read these\n**Funnel** — stage-to-stage drop-off from applications to placements.\n\n**Cohort** — each row is a client-acquisition month; columns are months since acquisition; cells show revenue (the post-acquisition revenue curve).\n\n**Margin bridge** — a waterfall from Revenue down through Labor Cost to Gross Margin (built from a query model; not affected by the Invoice Period filter). ;;
  }

