        }
      }
    }
    theme: holistics_ant_card_blocktheme_2a24b81
  }
  block t_5l6d: TextBlock {
    content: @md <img style="margin-left: -8px" src="https://cdn.holistics.io/logos/holistics-logo-white.svg" />;;
  }
  block t_4khz: block_ha_page_header_bg()
  block t_u2jy: block_ha_page_header('Sales and Orders', 'Monitor overall sales performance, order trends, and fulfillment outcomes to understand revenue drivers and operational efficiency.')
