Dashboard testing_claude {
  title: 'Testing Claude'

  block v1: VizBlock {
    label: 'Total Users by Age Demographic'
    viz: ColumnChart {
      dataset: demo_ecommerce_version_2
      x_axis: VizFieldFull {
        ref: r(ecommerce_users.age_group)
        label: 'Age Demographic'
      }
      y_axis {
        series {
          field: VizFieldFull {
            ref: r(demo_ecommerce_version_2.total_users)
            label: 'Total Users'
            format {
              type: 'number'
              pattern: '#,###0.00'
            }
          }
          settings {
            color: '#4F46E5'
          }
        }
      }
      settings {
        row_limit: 100
        sort: LineFamilySort {
          type: 'xaxis'
          direction: 'asc'
        }
      }
    }
  }
  block v2: VizBlock {
    label: 'Total Orders by Country'
    viz: BarChart {
      dataset: demo_ecommerce_version_2
      x_axis: VizFieldFull {
        label: 'Country Name'
        ref: r(ecommerce_countries.name)
        format {
          type: 'text'
        }
      }
      y_axis {
        series {
          field: VizFieldFull {
            label: 'Total Orders'
            ref: r(demo_ecommerce_version_2.total_orders)
            format {
              type: 'number'
              pattern: '#,###0.00'
            }
          }
          settings {
            color: '#F1434B'
          }
        }
        series {
          field: VizFieldFull {
            ref: r(ecommerce_countries.code)
            aggregation: 'count'
            format {
              type: 'number'
              pattern: 'inherited'
            }
          }
        }
      }
      settings {
        row_limit: 100
        sort {
          field_index: 0
          direction: 'desc'
          type: 'yaxis'
        }
        x_axis_label: 'Country Name'
        x_axis_show_null_datetime: true
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
      }
    }
  }
  block v_dzoj: VizBlock {
    label: 'Total Users by Age Demographic copy'
    viz: DataTable {
      dataset: demo_ecommerce_version_2
      fields: [
        VizFieldFull {
          ref: r(ecommerce_orders.created_at)
          transformation: 'datetrunc month'
          format {
            type: 'date'
            pattern: 'LLL yyyy'
          }
          uname: 'datetrunc_month_created_at'
        },
        r(ecommerce_users.age_group),
        VizFieldFull {
          ref: r(demo_ecommerce_version_2.total_users)
          format {
            type: 'number'
            pattern: '#,###0.00'
          }
        },
        VizFieldFull {
          ref: r(ecommerce_users.id)
          aggregation: 'count'
          format {
            type: 'number'
            pattern: 'inherited'
          }
        }
      ]
      settings {
        show_row_number: true
        row_limit: 100
        aggregate_awareness {
          enabled: true
          debug_comments: true
        }
        column_styles: [
          ColumnStyle {
            key: 'datetrunc_month_created_at'
            width: 150
          }
        ]
      }
    }
  }

  view: CanvasLayout {
    label: 'View 1'
    width: 1300
    height: 900
    grid_size: 20
    auto_expand_vertically: true
    block v1 {
      position: pos(20, 20, 620, 400)
    }
    block v2 {
      position: pos(660, 20, 620, 400)
    }
    block v_dzoj {
      position: pos(400, 460, 620, 400)
    }
  }
}